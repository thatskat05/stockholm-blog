---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import mePhoto from '../assets/101_0540.JPG';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
		<Image src={mePhoto} alt="me, excited and overpacked" width={200} class="float-photo" />
		<h1>välkommen! ⭐</h1>
	i'm katherine — physics + industrial engineering student...
			<h1>välkommen! 🇸🇪</h1>
				<p>
					i'm katherine — physics + industrial engineering student, coffee
					enthusiast, and as of august, temporary stockholmare. this is where
					i'm documenting a semester at KTH: the classes, the travel, the
					fika, and whatever else sweden throws at me.
				</p>
				<p>
					new here? start with the <a href="/blog">blog</a> or read <a href="/about"> about me</a>.
				</p>
		</main>
		<Footer />
	</body>
</html>

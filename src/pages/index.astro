---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import mePhoto from '../assets/101_0540.JPG';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
const [latestPost, ...olderPosts] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="layout">
				<div class="main-col">
					<div class="intro-box">
						<h1>välkommen! 🇸🇪</h1>
						<p>
							i'm katherine — physics + industrial engineering student, coffee
							enthusiast, and as of august, temporary stockholmare. this is where
							i'm documenting a semester at KTH: the classes, the travel, the
							fika, and whatever else sweden throws at me.
						</p>
						<p>
							new here? start with the <a href="/blog">blog</a> or read
							<a href="/about">about me</a>.
						</p>
					</div>

				{latestPost && (
	<div class="featured-post">
		<div class="box-title">✏️ latest post</div>
		{latestPost.data.heroImage && (
			<a href={`/blog/${latestPost.id}/`}>
				<Image src={latestPost.data.heroImage} alt="" width={280} class="featured-thumb" />
			</a>
		)}
		<h2 class="featured-title">
			<a href={`/blog/${latestPost.id}/`}>{latestPost.data.title}</a>
		</h2>
		<p class="date"><FormattedDate date={latestPost.data.pubDate} /></p>
		<p>{latestPost.data.description}</p>
		<p><a href={`/blog/${latestPost.id}/`}>read more »</a></p>
	</div>
)}

{olderPosts.length > 0 && (
	<>
		<h2>✏️ earlier posts</h2>
		<ul>
			{olderPosts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					<span class="date"> — <FormattedDate date={post.data.pubDate} /></span>
				</li>
			))}
		</ul>
	</>
)}
				</div>
				<div class="sidebar">
					<div class="retro-box" style="text-align: center;">
						<div class="box-title">me!!</div>
						<Image src={mePhoto} alt="me at the eiffel tower" width={200} />
					</div>
					<div class="retro-box">
	<div class="box-title">♪ the sverige soundtrack</div>
	currently building the playlist...<br /><br />
	<a href="https://open.spotify.com/playlist/78nZyqfLVcdS12o2ikTfqP">
		▶ listen on spotify
	</a>
</div>
					<div class="retro-box">
						<div class="box-title">currently...</div>
						reading: kalle blomkvist<br />
						drinking: filter coffee<br />
						mood: förväntansfull
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

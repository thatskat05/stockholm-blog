---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="the trinket shelf" description="trinkets collected abroad" />
		<style is:global>
			.shelf-stage { position: relative; width: 100%; overflow: hidden; }
			.shelf-bg { width: 100%; display: block; }
			.trinket { position: absolute; cursor: pointer; transform-origin: center center; transition: transform 0.3s ease; z-index: 2; }
			.trinket img { display: block; width: 100%; pointer-events: none; }
			.trinket.zoomed { z-index: 20; }
			.note-card { display: none; position: absolute; background: #fffdf7; border: 2px ridge #9db8d6; padding: 10px 12px; font-size: 10px; line-height: 1.7; color: #333; max-width: 160px; z-index: 25; pointer-events: none; }
			.note-card.active { display: block; }
			.note-card h3 { font-family: Georgia, serif; color: #2b4c7e; font-size: 12px; font-weight: normal; margin-bottom: 3px; border-bottom: 1px dotted #9db8d6; padding-bottom: 3px; }
			.note-card .loc { color: #888; font-style: italic; font-size: 9px; margin-bottom: 5px; }
			.note-card .close-hint { margin-top: 6px; color: #aaa; font-size: 9px; font-style: italic; }
			.empty-msg { text-align: center; font-size: 11px; color: #8b6f4e; font-style: italic; padding: 16px 0; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>the trinket shelf</h1>
			<p style="font-size:11px; color:#888; margin-bottom:16px;">things i've collected along the way. click anything to learn more.</p>

			<div class="shelf-stage" id="stage">
				<img class="shelf-bg" src="/shelf.png" alt="my trinket shelf" id="shelf-bg" />
				<div class="note-card" id="note-card">
					<h3 id="nc-name"></h3>
					<div class="loc" id="nc-loc"></div>
					<p id="nc-note"></p>
					<div class="close-hint">click anywhere to close</div>
				</div>
			</div>

			<p class="empty-msg" id="empty-msg">the shelf is empty for now — check back as i collect things! ✦</p>
		</main>
		<Footer />

		<script>
			const trinkets = [
				{
					name: "example trinket",
					img: "/example-trinket.png",
					location: "gamla stan, stockholm — september 2026",
					note: "tiny painted wooden horse. classic swedish folk art, got it from a market stall near the royal palace.",
					x: 18,
					y: 42,
					size: 6
				},
			];

			const ZOOM_TARGET = 300; /* all trinkets zoom to this width in px */

			const stage = document.getElementById('stage');
			const noteCard = document.getElementById('note-card');
			const emptyMsg = document.getElementById('empty-msg');
			const shelfBg = document.getElementById('shelf-bg');
			let active = null;

			if (trinkets.length > 0) emptyMsg.style.display = 'none';

			function placeTrinkets() {
				trinkets.forEach(t => {
					const div = document.createElement('div');
					div.className = 'trinket';
					div.style.left = t.x + '%';
					div.style.top = t.y + '%';
					div.style.width = t.size + '%';
					div.innerHTML = `<img src="${t.img}" alt="${t.name}" />`;

					div.addEventListener('click', e => {
						e.stopPropagation();
						if (active === div) { closeAll(); return; }
						closeAll();
						active = div;

						const stageW = stage.offsetWidth;
						const stageH = stage.offsetHeight;
						const trinketW = (t.size / 100) * stageW;
						const scale = ZOOM_TARGET / trinketW;
						div.classList.add('zoomed');
						div.style.transform = 'scale(' + scale + ')';

						setTimeout(() => {
							if (active !== div) return;
							const stageRect = stage.getBoundingClientRect();
							const tRect = div.getBoundingClientRect();
							const rightEdge = tRect.right - stageRect.left;
							const leftEdge = tRect.left - stageRect.left;
							const topEdge = tRect.top - stageRect.top;
							let cardX, cardY;
							if (rightEdge + 175 < stageW) {
								cardX = rightEdge + 6;
							} else {
								cardX = Math.max(4, leftEdge - 172);
							}
							cardY = Math.max(8, Math.min(topEdge, stageH - 170));
							noteCard.style.left = cardX + 'px';
							noteCard.style.top = cardY + 'px';
							document.getElementById('nc-name').textContent = t.name;
							document.getElementById('nc-loc').textContent = t.location;
							document.getElementById('nc-note').textContent = t.note;
							noteCard.classList.add('active');
						}, 310);
					});

					stage.appendChild(div);
				});
			}

			if (shelfBg.complete) {
				placeTrinkets();
			} else {
				shelfBg.addEventListener('load', placeTrinkets);
			}

			function closeAll() {
				document.querySelectorAll('.trinket').forEach(el => {
					el.classList.remove('zoomed');
					el.style.transform = '';
				});
				noteCard.classList.remove('active');
				active = null;
			}

			stage.addEventListener('click', closeAll);
		</script>
	</body>
</html>
